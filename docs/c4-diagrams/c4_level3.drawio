          <mxGeometry height="36" width="1000" x="320" y="3" as="geometry" />
        </mxCell>
        <mxCell id="boundary" parent="1" style="swimlane;startSize=34;fillColor=none;strokeColor=#82b366;strokeWidth=2;fontStyle=1;fontSize=13;fontColor=default;arcSize=3;" value="Express REST API  [Container: Node.js ≥22 + Express 4 · Port 3001]" vertex="1">
          <mxGeometry height="860" width="1499" x="60" y="72" as="geometry" />
        </mxCell>
        <mxCell id="l1_bg" parent="boundary" style="rounded=1;fillColor=#EEF7EE;strokeColor=#82b366;strokeWidth=1;arcSize=3;opacity=40;" value="" vertex="1">
