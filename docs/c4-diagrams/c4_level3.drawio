        </mxCell>
        <mxCell id="l1_label" parent="boundary" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=3;fontColor=#555555;" value="Route / Controller Layer" vertex="1">
          <mxGeometry height="18" width="200" x="30" y="56" as="geometry" />
        </mxCell>
        <mxCell id="authmw" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;" value="&lt;b&gt;authmw&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: middleware/auth.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;requireAuth — verifies Bearer JWT, attaches req.user. Returns 401 on failure. Applied via router.use()." vertex="1">
          <mxGeometry height="130" width="163" x="40" y="82" as="geometry" />
        </mxCell>
        <mxCell id="auth_api" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;" value="&lt;b&gt;auth_api&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: routes/auth.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;POST /register, POST /login (public). GET /me (protected). Maps SQLite UNIQUE → 409." vertex="1">
          <mxGeometry height="130" width="163" x="290" y="82" as="geometry" />
        </mxCell>
        <mxCell id="doc_api" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;" value="&lt;b&gt;doc_api&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: routes/documents.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;5 document routes. Delegates to doc_service.resolveDoc() for every write. Version snapshots triggered in service." vertex="1">
          <mxGeometry height="130" width="187" x="528" y="82" as="geometry" />
        </mxCell>
        <mxCell id="access_api" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;" value="&lt;b&gt;access_api&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: routes/access.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Owner-only sharing. Skips service layer intentionally — enforces owner check inline." vertex="1">
          <mxGeometry height="130" width="175" x="774" y="82" as="geometry" />
        </mxCell>
        <mxCell id="session_api" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;dashed=1;strokeWidth=2;" value="&lt;b&gt;session_api&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: routes/session.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Stub. Verifies access via repos, returns placeholder token scoped for Collab Server." vertex="1">
          <mxGeometry height="130" width="185" x="1010" y="82" as="geometry" />
        </mxCell>
        <mxCell id="ai_api" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;" value="&lt;b&gt;ai_api&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: routes/ai.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Calls resolveDoc() for access, then delegates AI work to ai_service." vertex="1">
          <mxGeometry height="130" width="184" x="1257" y="82" as="geometry" />
        </mxCell>
        <mxCell id="l2_bg" parent="boundary" style="rounded=1;fillColor=#FFF9E6;strokeColor=#d6b656;strokeWidth=1;arcSize=3;opacity=50;" value="" vertex="1">
