        </mxCell>
        <mxCell id="l2_label" parent="boundary" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=3;fontColor=#555555;" value="Service Layer" vertex="1">
          <mxGeometry height="18" width="120" x="30" y="316" as="geometry" />
        </mxCell>
        <mxCell id="auth_service" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;" value="&lt;b&gt;auth_service&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: services/auth.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;bcrypt (10 rounds) + HS256 JWT signing. publicUser() strips password_hash before response." vertex="1">
          <mxGeometry height="104" width="211" x="304" y="363" as="geometry" />
        </mxCell>
        <mxCell id="doc_service" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;" value="&lt;b&gt;doc_service&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: services/documents.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;resolveDoc() — central RBAC gate. updateDocument() triggers version snapshot on content change. listDocuments() merges owned + shared." vertex="1">
          <mxGeometry height="106" width="236" x="620" y="360" as="geometry" />
        </mxCell>
        <mxCell id="ai_service" parent="boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=default;fontSize=10;arcSize=5;verticalAlign=middle;" value="&lt;b&gt;ai_service&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: services/ai.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Inserts ai_interactions row before LLM call (audit-first). Calls llm_client.complete(). Updates row with response. Enables /ai/history." vertex="1">
          <mxGeometry height="114" width="244" x="996" y="357" as="geometry" />
        </mxCell>
